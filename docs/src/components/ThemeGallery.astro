---
const themes = [
    {
        name: 'Doodle Dark',
        src: '/images/studio/theme-dark.webp',
    },
    {
        name: 'Into the Forest',
        src: '/images/studio/theme-forest.webp',
    },
    {
        name: 'Outer Space',
        src: '/images/studio/theme-space.webp',
    },
    {
        name: 'Neon City',
        src: '/images/studio/theme-neon.webp',
    },
    {
        name: 'Deep Sea',
        src: '/images/studio/theme-deep-sea.webp',
    },
    {
        name: 'Terminal',
        src: '/images/studio/theme-terminal.webp',
    },
    {
        name: 'Storm',
        src: '/images/studio/theme-storm.webp',
    },
    {
        name: 'Royal Velvet',
        src: '/images/studio/theme-royal-velvet.webp',
    },
    {
        name: 'Pumpkin',
        src: '/images/studio/theme-pumpkin.webp',
    },
    {
        name: 'Blueprint',
        src: '/images/studio/theme-blueprint.webp',
    },
    {
        name: 'Sepia Noir',
        src: '/images/studio/theme-sepia-noir.webp',
    },
    {
        name: 'Firelight',
        src: '/images/studio/theme-firelight.webp',
    },
    {
        name: 'High Contrast',
        src: '/images/studio/theme-high-contrast.webp',
    },
    {
        name: 'Doodle Light',
        src: '/images/studio/theme-light.webp',
    },
    {
        name: 'Parchment',
        src: '/images/studio/theme-parchment.webp',
    },
    {
        name: 'Sakura',
        src: '/images/studio/theme-sakura.webp',
    },
    {
        name: 'Glacier',
        src: '/images/studio/theme-glacier.webp',
    },
];
---

<div class="theme-gallery">
    {
        themes.map((theme) => (
            <figure>
                <a href={theme.src}>
                    <img
                        src={theme.src}
                        alt={`Doodle Studio using the ${theme.name} theme and its default accent color`}
                        loading="lazy"
                        decoding="async"
                    />
                </a>
                <figcaption>{theme.name}</figcaption>
            </figure>
        ))
    }
</div>

<style>
    .theme-gallery {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        margin-block: 1.5rem;
    }

    figure {
        margin: 0;
        overflow: hidden;
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 0.5rem;
        background: var(--sl-color-bg-nav);
    }

    a,
    img {
        display: block;
    }

    img {
        width: 100%;
        margin: 0;
    }

    figcaption {
        padding: 0.6rem 0.75rem;
        color: var(--sl-color-text);
        font-weight: 600;
    }

    @media (max-width: 40rem) {
        .theme-gallery {
            grid-template-columns: 1fr;
        }
    }
</style>
