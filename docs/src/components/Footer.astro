---
import DefaultFooter from '@astrojs/starlight/components/Footer.astro';

const creatorUrl = 'https://katbella.com';
const issuesUrl = 'https://github.com/katbella/doodle-engine/issues';
const starlightUrl = 'https://starlight.astro.build';
---

<DefaultFooter />
<div class="project-footer">
    <a href={creatorUrl} target="_blank" rel="noopener noreferrer">
        Created by Kat Bella
    </a>
    <span aria-hidden="true">&bull;</span>
    <a href={issuesUrl} target="_blank" rel="noopener noreferrer">
        Having issues? Report them on GitHub!
    </a>
    <span aria-hidden="true">&bull;</span>
    <a href={starlightUrl} target="_blank" rel="noopener noreferrer">
        Docs built with Starlight
    </a>
</div>

<style>
    @layer starlight.core {
        .project-footer {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            justify-content: center;
            align-items: center;
            margin-bottom: 1.5rem;
            font-size: var(--sl-text-xs);
            color: var(--sl-color-gray-3);
        }

        .project-footer a {
            color: var(--sl-color-gray-2);
            text-decoration-line: underline;
            text-decoration-color: var(--sl-color-gray-4);
            text-decoration-thickness: 1px;
            text-underline-offset: 2px;
        }

        .project-footer a:hover {
            color: var(--sl-color-white);
            text-decoration-color: var(--sl-color-white);
            text-decoration-thickness: 2px;
        }

        .project-footer a:focus-visible {
            outline: 2px solid var(--sl-color-accent);
            outline-offset: 2px;
        }
    }
</style>
