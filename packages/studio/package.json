{
    "name": "@doodle-engine/studio",
    "version": "0.2.0",
    "private": true,
    "author": "Kat Bella",
    "license": "MIT",
    "main": "./out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "start": "electron-vite preview",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "vitest run",
        "test:unit": "vitest run --project unit",
        "test:integration": "vitest run --project integration",
        "test:journey": "vitest run --project journey",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "electron-vite build && yarn test:e2e:run",
        "test:e2e:run": "playwright test",
        "test:visual-tour": "electron-vite build && playwright test studio.e2e.ts",
        "package:win": "electron-vite build && electron-builder --win",
        "package:win:dir": "electron-vite build && electron-builder --win --dir",
        "package:mac": "electron-vite build && electron-builder --mac",
        "package:mac:dir": "electron-vite build && electron-builder --mac --dir"
    },
    "devDependencies": {
        "@doodle-engine/core": "workspace:*",
        "@doodle-engine/toolkit": "workspace:*",
        "@fontsource-variable/archivo": "^5.2.8",
        "@fontsource-variable/jetbrains-mono": "^5.2.8",
        "@monaco-editor/react": "^4.6.0",
        "@playwright/test": "^1.61.1",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/react": "^16.1.0",
        "@testing-library/user-event": "^14.5.2",
        "@types/node": "^24.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.3.0",
        "@vitest/coverage-v8": "4.1.6",
        "chokidar": "^4.0.0",
        "electron": "^33.2.0",
        "electron-builder": "26.15.3",
        "electron-vite": "^3.0.0",
        "jsdom": "^29.1.1",
        "lucide-react": "^1.24.0",
        "monaco-editor": "^0.52.0",
        "png-to-ico": "^3.0.2",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "typescript": "^5.7.0",
        "vite": "^6.4.2",
        "vitest": "^4.1.6",
        "yaml": "^2.8.3"
    },
    "build": {
        "appId": "com.doodle-engine.studio",
        "productName": "Doodle Studio",
        "electronVersion": "33.4.11",
        "directories": {
            "output": "release",
            "buildResources": "build"
        },
        "files": [
            "out/**/*",
            "resources/**/*",
            "package.json",
            "!**/node_modules/**"
        ],
        "npmRebuild": false,
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "build/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "shortcutName": "Doodle Studio",
            "artifactName": "doodle-studio-${version}-setup.${ext}"
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "universal"
                    ]
                }
            ],
            "icon": "build/icon.png",
            "identity": null,
            "artifactName": "doodle-studio-${version}-${arch}.${ext}"
        }
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
