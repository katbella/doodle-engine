{
    "name": "@doodle-engine/cli",
    "version": "0.2.1",
    "type": "module",
    "author": "Kat Bella",
    "license": "MIT",
    "description": "CLI tools for Doodle Engine game development",
    "bin": {
        "doodle": "./dist/cli.js"
    },
    "files": [
        "dist",
        "extensions"
    ],
    "scripts": {
        "dev": "vite build --watch",
        "build": "vite build && tsc -p tsconfig.json",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@doodle-engine/core": "workspace:*",
        "@doodle-engine/react": "workspace:*",
        "@doodle-engine/toolkit": "workspace:*",
        "commander": "^12.0.0",
        "crayon.js": "^3.3.0",
        "prompts": "^2.4.2",
        "vite": "^6.4.2"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "@types/prompts": "^2.4.9",
        "@vitest/coverage-v8": "4.1.6",
        "typescript": "^5.7.0",
        "vitest": "^4.1.6"
    },
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/katbella/doodle-engine",
        "directory": "packages/cli"
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
