{
    "name": "@doodle-engine/toolkit",
    "version": "0.2.2",
    "type": "module",
    "author": "Kat Bella",
    "license": "MIT",
    "description": "Reusable project services for Doodle Engine (load, validate, build, create) shared by the CLI and Doodle Studio",
    "main": "./dist/toolkit.cjs",
    "module": "./dist/toolkit.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/toolkit.js",
            "require": "./dist/toolkit.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite build --watch",
        "build": "vite build && tsc -p tsconfig.json",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@doodle-engine/core": "workspace:*",
        "@vitejs/plugin-react": "^4.3.0",
        "chokidar": "^4.0.0",
        "vite": "^6.4.2",
        "yaml": "^2.8.3"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "@vitest/coverage-v8": "4.1.6",
        "typescript": "^5.7.0",
        "vitest": "^4.1.6"
    },
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/katbella/doodle-engine",
        "directory": "packages/toolkit"
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
