{
    "name": "doodle-engine",
    "private": true,
    "author": "Kat Bella",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/katbella/doodle-engine"
    },
    "packageManager": "yarn@4.6.0",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "yarn workspaces foreach -At run build",
        "dev": "yarn workspaces foreach -Ap run dev",
        "test": "yarn workspaces foreach -A run test",
        "test:frontend": "yarn workspace @doodle-engine/react test && yarn workspace @doodle-engine/studio test",
        "test:coverage": "yarn workspaces foreach -A run test:coverage",
        "test:e2e": "yarn workspace @doodle-engine/studio test:e2e",
        "typecheck": "yarn workspace @doodle-engine/studio typecheck",
        "docs:dev": "yarn --cwd docs dev",
        "docs:build": "yarn --cwd docs build",
        "changeset": "changeset",
        "version": "changeset version",
        "release": "node scripts/publish.mjs"
    },
    "engines": {
        "node": ">=24.0.0"
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.8",
        "prettier": "3.8.1"
    }
}
